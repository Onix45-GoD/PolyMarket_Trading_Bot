# Copy to backend/.env (and optionally frontend/.env for Vite proxy only)

# --- Polymarket CLOB V2 ---
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
PRIVATE_KEY=0x...
DEPOSIT_WALLET_ADDRESS=
SIGNATURE_TYPE=3

# L2 API credentials (optional if you derive via PRIVATE_KEY on startup)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Builder (optional)
POLY_BUILDER_CODE=

# --- BTC price feed ---
BTC_PRICE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade

# --- Server ---
API_PORT=3001
WS_PORT=3002
API_HOST=0.0.0.0
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend (Vite) — set when using VPN ---
# Use 127.0.0.1 so traffic stays on loopback through the VPN tunnel
VITE_API_HOST=http://127.0.0.1:3001
VITE_WS_HOST=ws://127.0.0.1:3002

# --- Bot ---
BOT_MODE=dry-run
BOT_ENABLED=false
MAX_ORDER_SIZE_USD=10
MAX_DAILY_LOSS_USD=50
MIN_CONFIDENCE=0.6

# --- Market discovery (Gamma API) ---
GAMMA_API_URL=https://gamma-api.polymarket.com
BTC_UPDOWN_SEARCH=btc up down

# VPN: route Node outbound traffic through your VPN HTTP proxy (if supported)
# HTTPS_PROXY=http://127.0.0.1:7890

# If Gamma is blocked, paste token IDs from polymarket.com (market page / devtools)
# MANUAL_UP_TOKEN_ID=
# MANUAL_DOWN_TOKEN_ID=
# MANUAL_CONDITION_ID=
# MANUAL_MARKET_END_DATE=2026-05-18T12:05:00.000Z

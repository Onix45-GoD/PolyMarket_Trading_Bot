# Copy to project root .env (backend loads this + backend/.env)

# --- Polymarket CLOB V2 (required for live; optional for paper books) ---
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
PRIVATE_KEY=
DEPOSIT_WALLET_ADDRESS=
SIGNATURE_TYPE=3
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
POLY_BUILDER_CODE=

# --- BTC price ---
BTC_PRICE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade

# --- Server ---
API_PORT=3001
WS_PORT=3002
API_HOST=0.0.0.0
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
VITE_API_HOST=http://127.0.0.1:3001
VITE_WS_HOST=ws://127.0.0.1:3002

# --- Bot mode ---
# dry-run = PAPER (simulated money, no CLOB orders, auto settlement each window)
# live    = REAL (signed CLOB orders, FOK + both-leg confirm)
BOT_MODE=dry-run
BOT_ENABLED=false

# --- Paper (dry-run) only ---
VIRTUAL_STARTING_BALANCE_USD=1000

# --- Pair arb (paper + live) ---
MAX_PAIR_ORDER_SIZE=100
PAIR_BUY_COOLDOWN_MS=2000
MAX_DAILY_LOSS_USD=50
SLIPPAGE=0.02
BOT_TICK_MS=1000
MARKET_POLL_MS=500

# --- Live only (ignored in paper mode) ---
POLYGON_RPC_URL=https://polygon-rpc.com
RELAYER_URL=https://relayer-v2.polymarket.com/
# Gasless redeem via relayer (same builder API creds as CLOB if you have them)
# POLY_API_KEY=
# POLY_API_SECRET=
# POLY_API_PASSPHRASE=
LIVE_REDEEM_DELAY_MS=15000
LIVE_REDEEM_POLL_MS=10000
LIVE_REDEEM_MAX_WAIT_MS=600000
LIVE_ORDER_TYPE=FOK
LIVE_PAIR_CONFIRM_MS=1500
LIVE_ORDER_CANCEL_MS=1500
LIVE_ORDER_WATCH_MS=500
LIVE_EXPIRY_CANCEL_SEC=30
LIVE_BLOCK_WHILE_OPEN=true
LIVE_UNWIND_ONE_LEG=true

# --- Market discovery ---
GAMMA_API_URL=https://gamma-api.polymarket.com
BTC_UPDOWN_SLUG_PREFIX=btc-updown-5m
BTC_MARKET_WINDOW_MINUTES=5

# HTTPS_PROXY=http://127.0.0.1:7890
# MANUAL_UP_TOKEN_ID=
# MANUAL_DOWN_TOKEN_ID=
